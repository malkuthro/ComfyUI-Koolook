# ComfyUI-Koolook environment variables
#
# Copy this file to `.env` and fill in real paths for your machine.
# `.env` is gitignored — never commit real absolute paths to the public repo.
#
# Convention: KOLOOK_* prefix. Paths can be absolute or relative to MAIN.
# When unset, code/docs fall back to the documented portable default
# (when one exists).

# --- External forks root ----------------------------------------------------
# Where raw third-party clones live (outside MAIN). See forks/README.md.
# Default if unset: ../ComfyUI-Forks
KOLOOK_FORKS_DIR=

# --- Sibling projects -------------------------------------------------------
# Sibling projects are related repositories/folders we consult but do not
# fork or vendor. See README.md "Sibling Projects".

# ComfyUI knowledge database — sibling repository of ComfyUI references,
# workflow notes, and recipe research. Used by docs/agent skills as a
# read-only knowledge source.
# Default if unset: ../ComfyUI_knowledge___DB
KOLOOK_COMFYUI_KB_DIR=

# Personal knowledge database (Obsidian or similar) — entirely user-specific.
# Optional. Leave unset on shared/public clones; agents must treat the
# absence of this var as "no personal KB available".
# No default.
KOLOOK_PERSONAL_KB_DIR=

# --- Local dev sync ---------------------------------------------------------
# Path to the eventual Koolook subdirectory inside your live ComfyUI
# `custom_nodes/` folder, where `scripts/sync_to_dev.py` copies runtime
# files for fast local iteration (skip the publish-and-update round-trip
# for one-line fixes). Point at the leaf, NOT the parent — the parent
# `custom_nodes/` must already exist; the script can create the leaf
# itself with `--init` on first run. Leave unset to disable; the script
# errors out cleanly if invoked without it. Forward slashes work on
# Windows too. No default — entirely user-specific.
#
# Examples:
#   macOS:   /Volumes/Data/ComfyUI/custom_nodes/ComfyUI-Koolook
#   Linux:   /home/<user>/ComfyUI/custom_nodes/ComfyUI-Koolook
#   Windows: C:/ComfyUI_portable/ComfyUI/custom_nodes/ComfyUI-Koolook
#
# First-run on a fresh machine:
#   1. Set the variable here.
#   2. `python scripts/sync_to_dev.py --init` (creates the leaf folder)
#   3. From then on, plain `python scripts/sync_to_dev.py` is enough.
KOLOOK_COMFYUI_DEV_PATH=
